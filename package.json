{
	"name": "obsidian-pubmed-fetcher",
	"version": "1.2.1",
	"description": "Obsidian plugin to fetch article metadata from PubMed ID or DOI",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version-bump": "node version-bump.mjs",
		"version": "npm run version-bump",
		"postversion": "git push && git push --tags",
		"release": "npm run lint && npm test && npm run test:integration && npm run build",
		"lint": "eslint **/*.ts",
		"test": "mocha",
		"test:watch": "mocha --watch",
		"test:coverage": "c8 mocha",
		"test:integration": "node run-tests.js"
	},
	"keywords": [],
	"author": "Svend Gundestrup",
	"license": "AGPL-3.0",
	"devDependencies": {
		"@types/chai": "^4.3.20",
		"@types/mocha": "^10.0.6",
		"@types/node": "^16.11.6",
		"@types/sinon": "^21.0.0",
		"@types/sinon-chai": "^3.2.12",
		"@typescript-eslint/eslint-plugin": "^8.57.0",
		"@typescript-eslint/parser": "^8.57.0",
		"builtin-modules": "^5.0.0",
		"c8": "^11.0.0",
		"chai": "^4.5.0",
		"esbuild": "0.27.3",
		"eslint": "^10.0.3",
		"eslint-plugin-obsidianmd": "^0.1.9",
		"mocha": "^11.7.5",
		"obsidian": "latest",
		"sinon": "^21.0.2",
		"sinon-chai": "^3.7.0",
		"tslib": "^2.8.1",
		"tsx": "^4.7.1",
		"typescript": "^5.9.3"
	}
}
